# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000

# --- Admin dashboard (apps/admin) — copy apps/admin/.env.example ---
# VITE_API_URL=http://localhost:8000
# Google Sign-In (web client ID from Google Cloud Console → Web client)
VITE_GOOGLE_CLIENT_ID=

# Optional: browser error reporting (https://sentry.io)
VITE_SENTRY_DSN=
# Build/runtime label for Sentry (e.g. development, staging, production)
VITE_ENV=development
# Set true to show subscription / upgrade UI (profile page + header banner; hidden by default)
# VITE_SUBSCRIPTIONS_ENABLED=true

# OAuth (API verifies tokens; GOOGLE_CLIENT_ID should match the web client used by the SPA)
GOOGLE_CLIENT_ID=
APPLE_BUNDLE_ID=

# --- Mobile (Expo) — copy to mobile/.env ---
# EXPO_PUBLIC_API_URL=http://localhost:8000
# List endpoints use a single pagination envelope: { items, page, size, total, has_more, total_pages } (1-based page; total_pages = ceil(total/size)).
# Book uploads: POST /books/upload-url then HTTP PUT the file bytes to upload_url (presigned), then POST /books/ — never send PDFs through FastAPI.

# Migrations (Neon: set DATABASE_URL first, then): cd services/api && .venv/bin/alembic upgrade head
# Or from repo root: npm run db:migrate
# Async URL is optional; the API normalizes postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql://mindflip:mindflip@localhost:5432/mindflip
REDIS_URL=redis://localhost:6379/0

# Per-IP rate limit for /auth/login, /auth/register, /auth/google, /auth/apple (0 = off)
AUTH_RATE_LIMIT_WINDOW_SEC=60
AUTH_RATE_LIMIT_MAX_REQUESTS=40

JWT_SECRET=changeme-use-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_PATH=/auth
# strict | lax | none — leave empty to auto (none when Vercel preview CORS is on)
REFRESH_TOKEN_COOKIE_SAMESITE=

# Comma-separated browser origins (required for PDF uploads from the Vite app on :5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://admin.mindflip.io
# Allow all https://*.vercel.app origins (preview + production deploys on Vercel)
CORS_ALLOW_VERCEL_PREVIEWS=false
# Optional extra CORS origin regexes (comma-separated)
CORS_ORIGIN_REGEX=

# Required for POST /books/upload-url (presigned S3 PUT). Uploads fail without valid credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=mindflip-books
S3_REGION=us-east-1

# Check Celery worker: npm run check:celery
# Start worker: cd services/api && celery -A tasks.celery_app worker --loglevel=info

# Dev only — production uses AWS Secrets Manager (mindflip/anthropic-api-key)
ANTHROPIC_API_KEY=
# Model is fixed in code: claude-sonnet-4-20250514
ANTHROPIC_SECRET_ID=mindflip/anthropic-api-key
AWS_SECRETS_REGION=us-east-1

STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PREMIUM=
# Optional legacy fallback when only one price is used (maps to basic checkout)
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:5173

# Free-tier paywall: 3 books, 3 flashcard sets, 20 cards (UPGRADE_REQUIRED when exceeded)
# Set true in production; keep false while testing without subscription limits
FREE_TIER_PAYWALL_ENABLED=false

# Transactional email (https://resend.com) — never commit the real key
RESEND_API_KEY=
FROM_EMAIL=MindFlip <hello@mindflip.io>

# Optional: FastAPI error reporting (https://sentry.io)
SENTRY_DSN_API=
# Optional: POST /health/sentry-verify JSON body {"secret":"<value>"} — one test exception (FastAPI SDK)
SENTRY_VERIFY_SECRET=
# Sent to Sentry as environment (API + workers should use the same value per deploy)
ENVIRONMENT=development
