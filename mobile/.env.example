# Base URL for the FastAPI app (no trailing slash).
# Simulator/emulator: http://localhost:8000 often works.
# Physical phone/tablet: use your computer's LAN IP, e.g. http://192.168.1.5:8000 (localhost on the device is the device itself).
# Start the API bound to all interfaces if needed, e.g. uvicorn ... --host 0.0.0.0 --port 8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Pagination: list routes return { items, page, size, total, has_more, total_pages } (see GET /books/, GET /quiz-results/, GET /leaderboard).
# Uploads: POST /books/upload-url → PUT file to presigned URL → POST /books/ (PDF bytes never hit FastAPI).

# Optional — Google OAuth via expo-auth-session (native client IDs from Google Cloud Console)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional — native crash/error reporting (https://docs.sentry.io/platforms/react-native/)
# EXPO_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# Profile tab: “Send Sentry test event” appears when DSN is set (one intentional captured exception).
# Optional — Sentry environment tag (defaults to development if unset)
# EXPO_PUBLIC_ENV=development
# Set true to show subscription / upgrade UI on the profile tab (hidden by default)
# EXPO_PUBLIC_SUBSCRIPTIONS_ENABLED=true

